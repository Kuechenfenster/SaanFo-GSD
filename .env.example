# SaanFo Map - Environment Configuration Template
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8080
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION (Coolify PostgreSQL)
# ============================================
# Get this from Coolify database resource connection string
# Format: postgres://postgres:PASSWORD@HOST:5432/postgres
DATABASE_URL=postgres://postgres:your-password@hostname:5432/postgres

# Alternative: Individual connection parameters
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=saanfo_map
# DB_USER=postgres
# DB_PASSWORD=your-password

# ============================================
# FIREBASE CONFIGURATION
# ============================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="your-private-key"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Security
SESSION_SECRET=your-super-secret-session-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Email Newsletter (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: Map API
MAP_API_KEY=your-map-api-key
