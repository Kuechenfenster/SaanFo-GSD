# SaanFo Map - Environment Configuration Template
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8080
NODE_ENV=development

# Firebase Configuration
# Get these from your Firebase Console -> Project Settings -> Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="your-private-key"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Security
SESSION_SECRET=your-super-secret-session-key-change-in-production

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Email Newsletter (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: Map API (for Phase 5 - Deal Discovery)
MAP_API_KEY=your-map-api-key
